# Copy to config/dev/trading.env for local development overrides.
# These variables can override values in config/dev/runtime.yaml.

# SYMBOL=BTCUSDT
# VENUES=BINANCE,KRAKEN,OKX,COINBASE
# LOOP_INTERVAL_MS=1000

BINANCE_API_KEY=dev-binance-key
BINANCE_API_SECRET=dev-binance-secret

KRAKEN_API_KEY=dev-kraken-key
KRAKEN_API_SECRET=dev-kraken-secret

OKX_API_KEY=dev-okx-key
OKX_API_SECRET=dev-okx-secret

COINBASE_API_KEY=dev-coinbase-key
COINBASE_API_SECRET=dev-coinbase-secret
