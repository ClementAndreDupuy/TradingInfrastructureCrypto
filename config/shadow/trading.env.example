# Copy to config/shadow/trading.env and fill values as needed.
# Shadow mode uses mock:// endpoints, so default placeholders are acceptable.

# Optionally override defaults from run_shadow.sh
# SYMBOL=BTCUSDT
# VENUES=BINANCE,KRAKEN,OKX,COINBASE

# Separate shadow credentials (preferred). If omitted, script falls back to
# generic <VENUE>_API_KEY/<VENUE>_API_SECRET or local placeholder values.
SHADOW_BINANCE_API_KEY=shadow-binance-key
SHADOW_BINANCE_API_SECRET=shadow-binance-secret

SHADOW_KRAKEN_API_KEY=shadow-kraken-key
SHADOW_KRAKEN_API_SECRET=shadow-kraken-secret

SHADOW_OKX_API_KEY=shadow-okx-key
SHADOW_OKX_API_SECRET=shadow-okx-secret

SHADOW_COINBASE_API_KEY=shadow-coinbase-key
SHADOW_COINBASE_API_SECRET=shadow-coinbase-secret
